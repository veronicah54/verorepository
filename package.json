{
  "name": "emergency-healthcare-system",
  "version": "1.0.0",
  "description": "Online web-based application for emergency response and healthcare appointments",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "test": "jest",
    "install-all": "npm install && cd client && npm install",
    "seed": "node server/seeds/seedData.js",
    "start":  "nodemon server/server.js",
    "heroku-postbuild": "cd client && npm install && npm run build",
    "setup": "node setup.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "healthcare",
    "emergency",
    "appointments",
    "medical"
  ],
  "author": "Muuo Emmanuel",
  "license": "MIT"
}
